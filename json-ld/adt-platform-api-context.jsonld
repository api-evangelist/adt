      "@type": "xsd:string"
    },
    "automations": {
      "@id": "adt:automations",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "description": "schema:description",
    "deviceId": {
      "@id": "adt:deviceId",
      "@type": "xsd:string"
    },
    "timestamp": {
      "@id": "adt:timestamp",
      "@type": "xsd:dateTime"
    },
    "userId": {
      "@id": "adt:userId",
      "@type": "xsd:string"
    },
    "events": {
      "@id": "adt:events",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "total": {
      "@id": "adt:total",
      "@type": "xsd:integer"
    },
    "cameraId": {
      "@id": "adt:cameraId",
      "@type": "xsd:string"
    },
    "startTime": {
      "@id": "adt:startTime",
      "@type": "xsd:dateTime"
    },
    "endTime": {
      "@id": "adt:endTime",
      "@type": "xsd:dateTime"
    },
    "trigger": {
      "@id": "adt:trigger",
      "@type": "xsd:string"
    },
