    },
    "lastModified": {
      "@id": "adt:lastModified",
      "@type": "xsd:dateTime"
    },
    "devices": {
      "@id": "adt:devices",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "expiresAt": {
      "@id": "adt:expiresAt",
      "@type": "xsd:dateTime"
    },
    "permissions": {
      "@id": "adt:permissions",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "clips": {
      "@id": "adt:clips",
