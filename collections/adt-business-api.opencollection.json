{
  "opencollection": "1.0.0",
  "info": {
    "name": "ADT Business API",
    "version": "1"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "client_credentials",
      "accessTokenUrl": "https://auth.adt.com/oauth/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Sites",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "ADT List Business Sites",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.adt.com/business/v1/sites",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of sites to return."
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Pagination offset."
              }
            ]
          },
          "docs": "Retrieve all business sites with security systems for the authenticated account."
        },
        {
          "info": {
            "name": "ADT Get a Business Site",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.adt.com/business/v1/sites/:siteId",
            "params": [
              {
                "name": "siteId",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the business site."
              }
            ]
          },
          "docs": "Retrieve details of a specific business site including security status and device inventory."
        }
      ]
    },
    {
      "info": {
        "name": "Access Control",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "ADT List Access Control Credentials",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.adt.com/business/v1/sites/:siteId/access-control/credentials",
            "params": [
              {
                "name": "siteId",
                "value": "",
                "type": "path",
                "description": "Business site ID."
              }
            ]
          },
          "docs": "Retrieve all access control credentials (badges, PINs, biometric) assigned at a business site."
        },
        {
          "info": {
            "name": "ADT Create an Access Credential",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.adt.com/business/v1/sites/:siteId/access-control/credentials",
            "params": [
              {
                "name": "siteId",
                "value": "",
                "type": "path",
                "description": "Business site ID."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new access credential for a user at a business site."
        }
      ]
    },
    {
      "info": {
        "name": "Users",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "ADT List Site Users",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.adt.com/business/v1/sites/:siteId/users",
            "params": [
              {
                "name": "siteId",
                "value": "",
                "type": "path",
                "description": "Business site ID."
              }
            ]
          },
          "docs": "Retrieve all users with access to a business site."
        }
      ]
    },
    {
      "info": {
        "name": "Reports",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "ADT Generate Site Security Event Report",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.adt.com/business/v1/sites/:siteId/reports/events",
            "params": [
              {
                "name": "siteId",
                "value": "",
                "type": "path",
                "description": "Business site ID."
              },
              {
                "name": "startDate",
                "value": "",
                "type": "query",
                "description": "Report start date (ISO 8601)."
              },
              {
                "name": "endDate",
                "value": "",
                "type": "query",
                "description": "Report end date (ISO 8601)."
              }
            ]
          },
          "docs": "Generate a security event report for a business site including alarms, access events, and activity summaries."
        }
      ]
    }
  ],
  "bundled": true
}